generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email                String          @unique
  name                 String
  role                 UserRole
  password             String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  id                   Int             @id @default(autoincrement())
  isActive             Boolean         @default(true)
  lockUntil            DateTime?
  loginAttempts        Int             @default(0)
  resetPasswordExpires DateTime?
  resetPasswordToken   String?
  lastAttemptAt        DateTime?
  tokenVersion         Int             @default(0)
  studentProfile       Student?
  liaisonProfile       LiaisonOfficer?
  receivedMessages     Message[]       @relation("ReceivedMessages")
  sentMessages         Message[]       @relation("SentMessages")
  notifications        Notification[]
  supervisorProfile    Supervisor?

  @@map("users")
}

model Student {
  id                    Int             @id @default(autoincrement())
  userId                Int             @unique
  studentNumber         String          @unique
  fullName              String
  sex                   String?
  idOrPassport          String?
  dateOfBirth           DateTime?
  year                  String?
  graduationYear        String?
  phone                 String?
  email                 String?
  address               String?
  profileCompleted      Boolean         @default(false)
  profileToken          String?         @unique
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  companyName           String?
  companyAddress        String?
  companyPhone          String?
  companyEmail          String?
  companyPOBox          String?
  supervisorName        String?
  supervisorDesignation String?
  supervisorEmail       String?
  supervisorDepartment  String?
  supervisorPhone       String?
  liaisonOfficerName    String?
  liaisonOfficerPhone   String?
  internshipStart       DateTime?
  internshipEnd         DateTime?
  supervisorId          Int
  liaisonId             Int?
  absentDays            Int?            @default(0)
  liaison               LiaisonOfficer? @relation(fields: [liaisonId], references: [id])
  supervisor            Supervisor      @relation(fields: [supervisorId], references: [id])
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  iapReport             IapReport?
  logEntries            LogEntry[]
  ratings               Rating[]
  tasks                 Task[]
  weeklyLogs            WeeklyLog[]
}

model Supervisor {
  phone      String?
  department String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  students   Student[]
  ratings    Rating[]
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("supervisors")
}

model LiaisonOfficer {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  phone      String?
  department String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  students   Student[]
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("liaison_officers")
}

model Task {
  title             String
  description       String?
  status            TaskStatus @default(PENDING)
  date              DateTime   @default(now())
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  id                Int        @id @default(autoincrement())
  studentId         Int
  rating            Int?
  submissionContent String?
  submittedAt       DateTime?
  comments          Comment[]
  student           Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model WeeklyLog {
  id                  Int             @id @default(autoincrement())
  studentId           Int
  weekNumber          Int
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  startDate           DateTime
  endDate             DateTime
  mondayTask          String?
  mondayHours         Float?
  tuesdayTask         String?
  tuesdayHours        Float?
  wednesdayTask       String?
  wednesdayHours      Float?
  thursdayTask        String?
  thursdayHours       Float?
  fridayTask          String?
  fridayHours         Float?
  totalHours          Float?
  generalStatement    String?
  supervisorSignature Boolean         @default(false)
  supervisorName      String?
  supervisorDate      DateTime?
  supervisorNote      String?
  approvedAt          DateTime?
  status              WeeklyLogStatus @default(DRAFT)
  liaisonDate         DateTime?
  liaisonName         String?
  liaisonSignature    Boolean         @default(false)
  grade               String?
  dailyEntries        LogEntry[]
  student             Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, weekNumber])
  @@map("weekly_logs")
}

model LogEntry {
  id          Int        @id @default(autoincrement())
  studentId   Int
  content     String
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  mood        String?
  weeklyLogId Int?
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weeklyLog   WeeklyLog? @relation(fields: [weeklyLogId], references: [id])

  @@map("log_entries")
}

model Comment {
  content      String
  createdAt    DateTime @default(now())
  id           Int      @id @default(autoincrement())
  taskId       Int
  supervisorId Int?
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Rating {
  rating                 Int
  comment                String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  id                     Int        @id @default(autoincrement())
  studentId              Int        @unique
  supervisorId           Int
  complianceEtiquette    Int?       @default(0)
  cooperativeness        Int?       @default(0)
  knowledgeApplication   Int?       @default(0)
  knowledgeWirelessEst   Int?       @default(0)
  knowledgeWirelessMaint Int?       @default(0)
  knowledgeWirelessOps   Int?       @default(0)
  responsibility         Int?       @default(0)
  safetyArrangement      Int?       @default(0)
  safetyAwareness        Int?       @default(0)
  safetyCompliance       Int?       @default(0)
  evaluatorPosition      String?    @default("")
  evaluatorName          String?    @default("")
  student                Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor             Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

model Message {
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int?
  title      String
  message    String
  type       String    @default("INFO")
  link       String?
  read       Boolean   @default(false)
  createdAt  DateTime  @default(now())
  targetRole UserRole?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model IapReport {
  id                      Int      @id @default(autoincrement())
  studentId               Int      @unique
  nameOfUnit              String?
  overviewGoals           String?
  contentsTraining        String?
  loVisitCount            Int?
  isUseful                Boolean?
  improvedUnderstanding   Boolean?
  providedExperiences     Boolean?
  programmeTypes          String[]
  otherProgrammeDetails   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  futureCareerPlan        String?
  notableAchievements     String?
  satisfactionIndustry    String?
  satisfactionInstructors String?
  satisfactionMajor       String?
  satisfactionPractical   String?
  suggestions             String?
  student                 Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("iap_reports")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  STUDENT
  LIAISON
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SUBMITTED
  REJECTED
}

enum WeeklyLogStatus {
  DRAFT
  SUBMITTED
  REJECTED
  COMPLETED
}
