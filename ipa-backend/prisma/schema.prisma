generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email                String         @unique
  name                 String
  role                 UserRole
  password             String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  id                   Int            @id @default(autoincrement())
  isActive             Boolean        @default(true)
  lockUntil            DateTime?
  loginAttempts        Int            @default(0)
  resetPasswordExpires DateTime?
  resetPasswordToken   String?
  lastAttemptAt        DateTime?
  tokenVersion         Int            @default(0)
  studentProfile       Student?
  receivedMessages     Message[]      @relation("ReceivedMessages")
  sentMessages         Message[]      @relation("SentMessages")
  notifications        Notification[]
  supervisorProfile    Supervisor?

  @@map("users")
}

model Student {
  id                    Int         @id @default(autoincrement())
  userId                Int         @unique
  studentNumber         String      @unique
  fullName              String
  sex                   String?
  idOrPassport          String?
  dateOfBirth           DateTime?
  year                  String?
  graduationYear        String?
  phone                 String?
  email                 String?
  address               String?
  profileCompleted      Boolean     @default(false)
  profileToken          String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  companyName           String?
  companyAddress        String?
  companyPhone          String?
  companyEmail          String?
  companyPOBox          String?
  supervisorName        String?
  supervisorDesignation String?
  supervisorEmail       String?
  supervisorDepartment  String?
  supervisorPhone       String?
  liaisonOfficerName    String?
  liaisonOfficerPhone   String?
  internshipStart       DateTime?
  internshipEnd         DateTime?
  supervisorId          Int
  supervisor            Supervisor  @relation(fields: [supervisorId], references: [id])
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  iapReport             IapReport?
  logEntries            LogEntry[]
  ratings               Rating[]
  tasks                 Task[]
  weeklyLogs            WeeklyLog[]
}

model Supervisor {
  phone      String?
  department String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  students   Student[]
  ratings    Rating[]
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("supervisors")
}

model Task {
  title             String
  description       String?
  status            TaskStatus @default(PENDING)
  date              DateTime   @default(now())
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  id                Int        @id @default(autoincrement())
  studentId         Int
  rating            Int?
  submissionContent String?
  submittedAt       DateTime?
  comments          Comment[]
  student           Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model WeeklyLog {
  id                  Int             @id @default(autoincrement())
  studentId           Int
  weekNumber          Int
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  weekStart           DateTime
  weekEnd             DateTime
  mondayTask          String?
  mondayHours         Float?
  tuesdayTask         String?
  tuesdayHours        Float?
  wednesdayTask       String?
  wednesdayHours      Float?
  thursdayTask        String?
  thursdayHours       Float?
  fridayTask          String?
  fridayHours         Float?
  totalHours          Float?
  generalStatement    String?
  supervisorSignature Boolean         @default(false)
  supervisorName      String?
  supervisorDate      DateTime?
  supervisorNote      String?
  approvedAt          DateTime?
  status              WeeklyLogStatus @default(DRAFT)
  dailyEntries        LogEntry[]
  student             Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, weekNumber])
  @@map("weekly_logs")
}

model LogEntry {
  id          Int        @id @default(autoincrement())
  studentId   Int
  content     String
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  mood        String?
  weeklyLogId Int?
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weeklyLog   WeeklyLog? @relation(fields: [weeklyLogId], references: [id])

  @@map("log_entries")
}

model Comment {
  content      String
  createdAt    DateTime @default(now())
  id           Int      @id @default(autoincrement())
  taskId       Int
  supervisorId Int?
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Rating {
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  id           Int        @id @default(autoincrement())
  studentId    Int
  supervisorId Int
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

model Message {
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int?
  title      String
  message    String
  type       String    @default("INFO")
  link       String?
  read       Boolean   @default(false)
  createdAt  DateTime  @default(now())
  targetRole UserRole?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model IapReport {
  id                    Int      @id @default(autoincrement())
  studentId             Int      @unique
  loVisitCount          Int?
  isUseful              Boolean?
  improvedUnderstanding Boolean?
  providedExperiences   Boolean?
  programmeTypes        String[]
  otherProgrammeDetails String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  student               Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("iap_reports")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  STUDENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SUBMITTED
  APPROVED
  REJECTED
}

enum WeeklyLogStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}
